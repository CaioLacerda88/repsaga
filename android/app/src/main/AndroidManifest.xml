<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Phase 30 PR 30b Pass 2: share-card capture flow.
         CAMERA: required when the user taps "Camera" in the share photo bottom
         sheet (handled gracefully by `permission_handler` — denial falls back
         to the Discreet variant per the share-card mockup §6 contract).
         READ_MEDIA_IMAGES is NOT declared: `image_picker` 1.x uses the
         photo-picker on Android 13+ which doesn't require the runtime
         permission. Older devices still work because image_picker delegates
         to the system photo intent. -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <application
        android:label="RepSaga"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        tools:replace="android:allowBackup">
        <!-- enableOnBackInvokedCallback is deliberately UNSET — but note
             this is a no-op on this app's compile/target SDK (36): the
             Android attribute defaults to "true" for targetSdk >= 34
             (predictive back is opt-OUT, not opt-IN, post-API-34). The
             real fix for the L13 "back exits the app" symptom lives in
             `lib/core/router/app_router.dart` — see the
             NotificationListener<NavigationNotification> wrap around
             `BackButtonListener` in `_ShellScaffoldState.build`. The
             chain that was failing: inner `_CustomNavigator`'s
             `NavigationNotification(canHandlePop: false)` bubbled to
             `WidgetsApp._defaultOnNavigationNotification` → called
             `SystemNavigator.setFrameworkHandlesBack(false)` →
             unregistered Flutter's OnBackInvokedCallback → Android
             handled back natively (`Activity.finish()`) and Flutter
             never saw the press. PopScope + the manifest flag tweaks
             were both treating symptoms; the actual gate is the
             NavigationNotification → setFrameworkHandlesBack contract. -->
        <!-- allowBackup retained per below comment. -->
        <!-- (Manifest flag intentionally not set, kept for explicitness.) -->

        <!-- allowBackup=false: prevents Android auto-backup from restoring
             stale Hive box files across uninstall→reinstall cycles. The on-disk
             Hive binary embeds typeIds — if backup-restored data references
             typeIds that the new APK's adapter set has dropped/renumbered,
             the next launch's Hive.openBox throws HiveError and bricks the
             app on the splash screen. RepSaga is fully cloud-backed
             (auth/workouts/PRs in Supabase), so local data is replaceable;
             losing it on uninstall is an acceptable trade.

             tools:replace handles the merge with manifests from any plugin
             (e.g. observability libs) that declares allowBackup=true. -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Deep link for Supabase OAuth callback -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="io.supabase.repsaga"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Phase 30 PR 30b Pass 2: image_picker needs to resolve camera +
             gallery intents on Android 11+ (package visibility, API 30+).
             Per image_picker README:
             https://pub.dev/packages/image_picker#android -->
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.GET_CONTENT"/>
            <data android:mimeType="image/*"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.PICK"/>
            <data android:mimeType="image/*"/>
        </intent>
    </queries>
</manifest>
